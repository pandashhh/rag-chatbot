# ============================================================
# .env.example – Vorlage für deine API-Keys
# ============================================================
# ANLEITUNG:
# 1. Diese Datei kopieren:  cp .env.example .env
# 2. In der .env deine echten Keys eintragen
# 3. Die .env Datei NIE auf GitHub pushen! (steht in .gitignore)

# Anthropic API Key – brauchst du für:
# - Text-Embeddings (Dokumente in Zahlen umwandeln) via HuggingFace (kostenlos)
# - Claude als LLM für die Antworten
# Holen unter: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...dein-key-hier...

# Name der ChromaDB Collection (kannst du so lassen)
CHROMA_COLLECTION_NAME=rag_documents
